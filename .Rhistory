data <- data %>%
rowwise() %>%
mutate(
# Actor*_initiator: Assign 1 for the actor with the highest value > 0
across(starts_with("actor") & ends_with("_initiator"),
~ ifelse(. == max(c_across(starts_with("actor") & ends_with("_initiator")), na.rm = TRUE) & . > 0, 1, 0)),
# Actor*_perpetrator: Assign 1 if the value > 0 and corresponding _bystander < 1
across(starts_with("actor") & ends_with("_perpetrator"),
~ ifelse(. > 0 & get(gsub("_perpetrator", "_bystander", cur_column())) < 1, 1, 0)),
# Actor*_intervener: Assign 1 if the value > 0 and corresponding _initiator == 0
across(starts_with("actor") & ends_with("_intervener"),
~ ifelse(. > 0 & get(gsub("_intervener", "_initiator", cur_column())) == 0, 1, 0)),
# Actor*_bystander: Assign 1 if the value > 0 and corresponding _initiator, _perpetrator, and _intervener == 0
across(starts_with("actor") & ends_with("_bystander"),
~ ifelse(. > 0 &
get(gsub("_bystander", "_initiator", cur_column())) == 0 &
get(gsub("_bystander", "_perpetrator", cur_column())) == 0 &
get(gsub("_bystander", "_intervener", cur_column())) == 0, 1, 0))
) %>%
ungroup()
# Test: Ensure the sum of actor*_initiator is never > 1
data <- data %>%
mutate(initiator_sum = actor1_initiator + actor2_initiator + actor3_initiator +
actor4_initiator + actor5_initiator + actor6_initiator)
expect_true(all(data$initiator_sum <= 1), info = "The sum of actor*_initiator columns exceeds 1 in at least one row.")
View(data)
